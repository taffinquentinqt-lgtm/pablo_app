{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/mentions-legales",
      "destination": "/mentions-legales.html"
    },
    {
      "source": "/eleveurs",
      "destination": "/eleveurs.html"
    },
    {
      "source": "/test",
      "destination": "/test.html"
    },
    {
      "source": "/fiche/:id",
      "destination": "/fiche.html"
    },
    {
      "source": "/blog/ration-berger-allemand",
      "destination": "/blog/ration-berger-allemand.html"
    },
    {
      "source": "/blog/calendrier-vaccins-chiot",
      "destination": "/blog/calendrier-vaccins-chiot.html"
    },
    {
      "source": "/blog/suivi-poids-chiot",
      "destination": "/blog/suivi-poids-chiot.html"
    },
    {
      "source": "/blog/alimentation-chiot-croissance",
      "destination": "/blog/alimentation-chiot-croissance.html"
    },
    {
      "source": "/blog/carnet-sante-chien-numerique",
      "destination": "/blog/carnet-sante-chien-numerique.html"
    },
    {
      "source": "/blog/rappel-vaccin-chien",
      "destination": "/blog/rappel-vaccin-chien.html"
    },
    {
      "source": "/blog/application-eleveur-canin",
      "destination": "/blog/application-eleveur-canin.html"
    }
  ]
}
